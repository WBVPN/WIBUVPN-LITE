export HOME=/root
export TERM=xterm

username="$1"
bulan="$2"
ip="$3"

if [[ -z "$username" || -z "$bulan" || -z "$ip" ]]; then
  echo "❌ Parameter tidak lengkap. Gunakan: <username> <bulan> <ip>"
  exit 1
fi

exp_days=$((bulan * 30))
exp_date=$(date -d "+$exp_days days" +"%Y-%m-%d")


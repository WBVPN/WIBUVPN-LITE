            11) clear ; m_bot ;;
            12) clear ; m_bot_notif ;;
            13) clear ; m-backup ;;
            14) clear ; bw_monitor ;;
            15) clear ; show_server_status ;;
            16) clear ; reboot ;;
            17) clear ; manage_dropbear_version ;;
            18) clear ; nano /etc/banner-ssh.txt ; read -n 1 -s -r -p "Press [ Enter ] to back on menu" ; main_menu ;;

memasang_info() {
  MYIP=$(curl -sS icanhazip.com)
  local izinsc="https://raw.githubusercontent.com/WBVPN/WIBUVPN-LITE/main/ip"
  
  local IP_DATA_LINE=$(curl -s "$izinsc" | grep -w "$MYIP" | head -1)

  client_name=$(echo "$IP_DATA_LINE" | awk '{print $2}')
  local exp=$(echo "$IP_DATA_LINE" | awk '{print $3}')

  local OS=$(lsb_release -d | cut -f2)
  local RAM_TOTAL=$(free -m | awk '/Mem:/ {print $2}')
  local RAM_USED=$(free -m | awk '/Mem:/ {print $3}')
  local UPTIME=$(uptime -p | sed 's/up //')
  local CPU_MODEL=$(awk -F ': ' '/^model name/ {name=$2} END {print name}' /proc/cpuinfo | head -n 1)
  local DOMAIN_VAL=$(cat /etc/xray/domain 2>/dev/null || echo "undefined")

  local TODAY_DATE_FORMATTED=$(date +'%Y-%m-%d')

  if [[ "$exp" == "lifetime" ]]; then
    EXPIRE_INFO="${BIBlue}Lifetime${NC}"
  elif [[ -n "$exp" ]]; then
    local exp_timestamp_val=$(date -d "$exp" +%s 2>/dev/null)
    local today_timestamp_val=$(date -d "$TODAY_DATE_FORMATTED" +%s 2>/dev/null)

    if [[ $? -eq 0 && -n "$exp_timestamp_val" && -n "$today_timestamp_val" ]]; then
      local days_left=$(((exp_timestamp_val - today_timestamp_val) / 86400))
      local expire_date_formatted=$(date -d "$exp" +"%d-%m-%Y" 2>/dev/null)
      
      local status_text="${BIBlue}Active${NC}"
      if (( days_left <= 0 )); then
        status_text="${RED}Expired${NC}"
      elif (( days_left == 0 )); then
        status_text="${Lime}Today Expire${NC}"
      fi
      EXPIRE_INFO="${Lime}$expire_date_formatted${NC} ${BIWhite}$days_left Days${NC} $status_text"
    else
      EXPIRE_INFO="${RED}Unknown${NC}" 
    fi
  else
    EXPIRE_INFO="${RED}Unknown${NC}"
  fi
}

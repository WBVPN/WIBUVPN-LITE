    function check_ssh_login() {
        clear
        echo -e "\033[1;36m-----------------------------------------\033[0m"
        echo -e "\033[1;36m User SSH Logins \033[0m"
        echo -e "\033[1;36m-----------------------------------------\033[0m"

        local LOG=""
        if [ -e "/var/log/auth.log" ]; then
            LOG="/var/log/auth.log";
        elif [ -e "/var/log/secure" ]; then
            LOG="/var/log/secure";
        else
            echo "Log file not found!"
            read -n 1 -s -r -p "Press any key to back on menu"
            m_ssh
            return 1
        fi

        local TEMP_LOG_DIR="/tmp/ssh_logs"
        mkdir -p "$TEMP_LOG_DIR"
        local TEMP_LOGIN_DB="$TEMP_LOG_DIR/login-db.txt"
        local TEMP_LOGIN_SSHD="$TEMP_LOG_DIR/login-sshd.txt"
        local TEMP_USER_LOGIN_IPS="$TEMP_LOG_DIR/user_login_ips.txt"
        local TEMP_UNIQUE_USER_LOGIN_IPS="$TEMP_LOG_DIR/unique_user_login_ips.txt"

        > "$TEMP_USER_LOGIN_IPS"

        grep -i "dropbear" "$LOG" | grep -i "Password auth succeeded" > "$TEMP_LOGIN_DB"
        local dropbear_pids=($(ps aux | grep -i dropbear | awk '{print $2}'))
        for PID in "${dropbear_pids[@]}"; do
            local login_info=$(grep "dropbear\[$PID\]" "$TEMP_LOGIN_DB")
            if [ -n "$login_info" ]; then
                local USER=$(echo "$login_info" | awk '{print $10}')
                local IP=$(echo "$login_info" | awk '{print $12}')
                echo "$USER $IP" >> "$TEMP_USER_LOGIN_IPS"
            fi
        done

        grep -i "sshd" "$LOG" | grep -i "Accepted password for" > "$TEMP_LOGIN_SSHD"
        local sshd_pids=($(ps aux | grep "\[priv\]" | awk '{print $2}'))
        for PID in "${sshd_pids[@]}"; do
            local login_info=$(grep "sshd\[$PID\]" "$TEMP_LOGIN_SSHD")
            if [ -n "$login_info" ]; then
                local USER=$(echo "$login_info" | awk '{print $9}')
                local IP=$(echo "$login_info" | awk '{print $11}')
                echo "$USER $IP" >> "$TEMP_USER_LOGIN_IPS"
            fi
        done

        cat "$TEMP_USER_LOGIN_IPS" | sort | uniq > "$TEMP_UNIQUE_USER_LOGIN_IPS"

        local users=($(awk '{print $1}' "$TEMP_UNIQUE_USER_LOGIN_IPS" | sort | uniq))

        for user in "${users[@]}"; do
            local ip_count=$(grep -w "$user" "$TEMP_UNIQUE_USER_LOGIN_IPS" | awk '{print $2}' | sort -u | wc -l)
            echo "User: $user - IP Count: $ip_count"
            echo "Logged IPs:"
            grep -w "$user" "$TEMP_UNIQUE_USER_LOGIN_IPS" | awk '{print $2}' | sort -u | nl
            echo ""
        done

        if [ -f "/etc/openvpn/server/openvpn-tcp.log" ]; then
            echo ""
            echo -e "\033[1;36m---------------------------------------------\033[0m"
            echo "    Username  |  IP Address  |  Connected";
            echo -e "\033[1;36m---------------------------------------------\033[0m"
            cat /etc/openvpn/server/openvpn-tcp.log | grep -w "^CLIENT_LIST" | cut -d ',' -f 2,3,8 | sed -e 's/,/      /g'
        fi

        if [ -f "/etc/openvpn/server/openvpn-udp.log" ]; then
            echo " "
            echo -e "\033[1;36m---------------------------------------------\033[0m"
            echo "    Username  |  IP Address  |  Connected";
            echo -e "\033[1;36m---------------------------------------------\033[0m"
            cat /etc/openvpn/server/openvpn-udp.log | grep -w "^CLIENT_LIST" | cut -d ',' -f 2,3,8 | sed -e 's/,/      /g'
        fi

        rm -rf "$TEMP_LOG_DIR"

        echo ""
        read -n 1 -s -r -p "Press any key to back on menu"
        m_ssh
    }


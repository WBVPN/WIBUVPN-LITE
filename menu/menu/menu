              Quota="0"
            fi

            local c=$(echo "${Quota}" | sed 's/[^0-9]*//g')
            local d=$((${c} * 1024 * 1024 * 1024))

            if [[ ${c} != "0" ]]; then
              echo "${d}" >/etc/trojan/${user}
            fi
            
            local now=$(date +%Y-%m-%d)
            local d1=$(date -d "$exp" +%s)
            local d2=$(date -d "$now" +%s)
            local exp2=$(( (d1 - d2) / 86400 ))
            local exp3=$(($exp2 + $masaaktif))

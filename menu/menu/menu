    function change_ssh_quota() {
        clear
        echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
        echo -e "${YELLOW_SSH}   USERNAME       EXP DATE         STATUS${RESET}"
        echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
        
        while read user_line; do
            local AKUN=$(echo "$user_line" | cut -d: -f1)
            local ID=$(echo "$user_line" | cut -d: -f3)
            if [[ $ID -ge 1000 ]]; then
                local exp=$(chage -l "$AKUN" 2>/dev/null | grep "Account expires" | awk -F": " '{print $2}')
                local status=$(passwd -S "$AKUN" 2>/dev/null | awk '{print $2}')
                if [[ "$status" == "L" ]]; then
                    printf "%-17s %-17s ${RED}%s${RESET}\n" "$AKUN" "$exp" "LOCKED"
                else
                    printf "%-17s %-17s ${GREEN}%s${RESET}\n" "$AKUN" "$exp" "UNLOCKED"
                fi
            fi
        done < /etc/passwd

        echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
        local JUMLAH=$(awk -F: '$3 >= 1000 {print $1}' /etc/passwd | wc -l)
        echo -e "${YELLOW_SSH}   Total Users: $JUMLAH${RESET}"
        echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
        echo ""

        read -p "Input username: " user
        local quota_file="/etc/ssh/$user"
        
        if [ -e "$quota_file" ]; then
            local current_quota=$(cat "$quota_file")
            echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
            echo -e "${GREEN}Current Quota for $user: $((current_quota / 1024 / 1024 / 1024)) GB${RESET}"
            echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
        else
            echo -e "${RED}No quota set for $user.${RESET}"
        fi

        read -p "Enter new quota (in GB): " new_quota
        if [[ -z "$new_quota" || ! "$new_quota" =~ ^[0-9]+$ ]]; then
            echo -e "${RED}Invalid input. No changes made.${RESET}"
            read -n 1 -s -r -p "Press any key to back on menu"
            m_ssh
            return 1
        fi

        local new_quota_bytes=$((new_quota * 1024 * 1024 * 1024))
        mkdir -p "$(dirname "$quota_file")" &>/dev/null
        echo "$new_quota_bytes" > "$quota_file"

        echo -e "${CYAN_SSH}---------------------------------------------${RESET}"
        echo -e "${GREEN}Quota successfully updated.${RESET}"
        echo -e "${GREEN}Username   : $user${RESET}"
        echo -e "${GREEN}New Quota  : $new_quota GB${RESET}"
        echo -e "${CYAN_SSH}---------------------------------------------${RESET}"

        local db_file="/etc/ssh/.ssh.db"
        mkdir -p "$(dirname "$db_file")" &>/dev/null
        
        local DATADB=$(grep "^#ssh# ${user} " "$db_file" 2>/dev/null || true)
        local ge=$(grep -w "$user" /etc/limit/ssh/ip 2>/dev/null || echo 0) # This 'ge' variable seems unused or incorrectly handled

        if [[ -n "$DATADB" ]]; then
            sed -i "/^#ssh# ${user} /d" "$db_file"
        fi

        echo "#ssh# ${user} $(date +%Y-%m-%d) ${new_quota_bytes}" >> "$db_file"
        # The line below looks like a copy-paste error; it's writing to 'ge' (which is likely a path) not a file content.
        # echo "#ssh# ${user} $(date +%Y-%m-%d) ${new_quota_bytes}" >> "$ge"
        echo -e "${GREEN}Database successfully updated.${RESET}"
        
        read -n 1 -s -r -p "Press any key to back on menu"
        m_ssh
    }


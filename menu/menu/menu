    function lock_vless_user() {
        local LOCK_FILE="/etc/user_locks.db"
        local XRAY_CONFIG="/etc/xray/config.json"
        local BACKUP_DIR="/etc/xray/backups"

        [[ ! -f "$LOCK_FILE" ]] && touch "$LOCK_FILE"
        [[ ! -d "$BACKUP_DIR" ]] && mkdir -p "$BACKUP_DIR"

        function reload_services() {
            systemctl restart xray &>/dev/null
            echo -e "${Lime}Xray service has been reloaded.${NC}"
            read -n 1 -s -r -p "Press any key to back on menu"
            m_vless
        }

        function modify_xray_config() {
            local action="$1"
            local user="$2"
            local protocol="vless"
            local marker="#& $user"

            if [[ "$action" == "lock" ]]; then
                cp "$XRAY_CONFIG" "$BACKUP_DIR/config.json.bak"
                sed -i "/^${marker}/,/^},{/d" "$XRAY_CONFIG"
                echo -e "${Lime}User '${user}' on protocol '${protocol}' has been locked.${NC}"
            elif [[ "$action" == "unlock" ]]; then
                if [[ -f "$BACKUP_DIR/config.json.bak" ]]; then
                    cp "$BACKUP_DIR/config.json.bak" "$XRAY_CONFIG"
                    echo -e "${Lime}User '${user}' on protocol '${protocol}' has been restored from the backup.${NC}"
                else
                    echo -e "${BIWhite}Backup not found! Failed to unlock user '${user}'.${NC}"
                fi
            fi
        }

        clear
        echo -e "${Lime}---------------------------------------------${NC}"
        echo -e "${BIWhite}LOCK VLESS ACCOUNT${NC}"
        echo -e "${Lime}---------------------------------------------${NC}"

        mapfile -t all_users < <(grep -E "^#& " "$XRAY_CONFIG" | cut -d ' ' -f 2 | sort | uniq)
        mapfile -t locked_users < <(grep "^vless:" "$LOCK_FILE" | cut -d ':' -f2)

        available_users=()
        for user in "${all_users[@]}"; do
            local found_locked=0
            for locked_user_item in "${locked_users[@]}"; do
                if [[ "$user" == "$locked_user_item" ]]; then
                    found_locked=1
                    break
                fi
            done
            if [[ "$found_locked" -eq 0 ]]; then
                available_users+=("$user")
            fi
        done

        if [[ ${#available_users[@]} -eq 0 ]]; then
            echo -e "${RED}Tidak Ada User Aktif Yang Di Temukan${NC}"
            read -n 1 -s -r -p "Tekan tombol apapun untuk kembali ke menu"
            m_vless
            return
        fi

        for i in "${!available_users[@]}"; do
            echo -e "${BILime}$((i+1)). ${available_users[$i]}${NC}"
        done

        echo -e "${Lime}---------------------------------------------${NC}"
        read -p "Pilih nomor user yang ingin dikunci: " selected

        if ! [[ "$selected" =~ ^[0-9]+$ ]] || (( selected < 1 || selected > ${#available_users[@]} )); then
            echo -e "${RED}Pilihan tidak valid.${NC}"
            return
        fi

        local user="${available_users[$((selected-1))]}"

        echo "vless:${user}" >> "$LOCK_FILE"

        modify_xray_config "lock" "$user"

        reload_services
    }

    function unlock_vless_user() {
        local LOCK_FILE="/etc/user_locks.db"
        local XRAY_CONFIG="/etc/xray/config.json"
        local BACKUP_DIR="/etc/xray/backups"

        [[ ! -f "$LOCK_FILE" ]] && touch "$LOCK_FILE"

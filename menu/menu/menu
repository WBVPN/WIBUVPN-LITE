main_menu() {
    while true; do
        clear
        
        collect_server_info
        check_all_service_status
        collect_usage_stats
        memasang_info
             
        PERMISSION
        display_menu_header
        display_service_status
        display_user_stats
        
        display_menu_options
        display_menu_footer

        read -p " Select menu : " opt
        echo -e ""
        case $opt in
            1) clear ; m_ssh ;;
            2) clear ; m_vmess ;;
            3) clear ; m_vless ;;
            4) clear ; m_trojan ;;
            5) clear ; m_shadowsocks ;;
            6) clear ; m_nob ;;

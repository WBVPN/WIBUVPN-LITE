        fi

        clear
        echo -e "${BIWhite}──────────────────────────────────────${NC}"
        echo -e "${Lime}AUTOREBOOT SETUP${NC}"
        echo -e "${BIWhite}──────────────────────────────────────${NC}"
        echo -e "
${BIWhite}    Example :${NC} ${Lime}

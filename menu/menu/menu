            rm -f /usr/bin/api-lite.zip
        fi
        if [ -e /usr/bin/api-lite ]; then
            rm -rf /usr/bin/api-lite
        fi
        
        install_node_js
        rm /var/lib/dpkg/stato* &>/dev/null
        rm /var/lib/dpkg/lock* &>/dev/null

        if [ ! -f /usr/bin/api-lite/api.js ]; then
            curl -sL "${link_downloadfile}WIBUVPN-LITE/main/files/api-lite.zip" -o /usr/bin/api-lite.zip
            cd /usr/bin || return 1
            unzip -o -P killer-project api-lite.zip &>/dev/null

calculate_cpu_load() {
    read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    total_cpu_time_1=$((user + nice + system + idle + iowait + irq + softirq + steal))
    idle_time_1=$idle

    sleep 0.5

    read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
    total_cpu_time_2=$((user + nice + system + idle + iowait + irq + softirq + steal))
    idle_time_2=$idle

    total_diff=$((total_cpu_time_2 - total_cpu_time_1))
    idle_diff=$((idle_time_2 - idle_time_1))

    if (( total_diff == 0 )); then
        LOADCPU="0.0%"
    else
        cpu_usage_raw=$(echo "scale=2; 100 * ($total_diff - $idle_diff) / $total_diff" | bc)
        LOADCPU=$(printf "%.1f%%" "$cpu_usage_raw")
    fi
}

PERMISSION() {
    MYIP=$(curl -sS icanhazip.com)

    TODAY_DATE=$(date +'%Y-%m-%d')

    AUTHORIZED_ENTRY=$(curl -sS https://raw.githubusercontent.com/WBVPN/WIBUVPN-LITE/main/ip?v=$RANDOM | grep -w "$MYIP" | head -1)

    if [[ -n "$AUTHORIZED_ENTRY" ]]; then

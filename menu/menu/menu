    function delete_expired_ssh_accounts() {
        clear
        local CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3 2>/dev/null)
        local KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2 2>/dev/null)
        local URL="https://api.telegram.org/bot$KEY/sendMessage"
        local hariini=$(date +%d-%m-%Y)
        echo -e "Thank you for removing the EXPIRED USERS"
        echo -e "${ORANGE_SSH}--------------------------------------${NC}"
        
        cat /etc/shadow | cut -d: -f1,8 | sed /:$/d > /tmp/expirelist.txt
        local totalaccounts=$(cat /tmp/expirelist.txt | wc -l)

        for ((i = 1; i <= $totalaccounts; i++)); do
            local tuserval=$(sed -n "${i}p" /tmp/expirelist.txt)
            local username=$(echo "$tuserval" | cut -f1 -d:)
            local userexp=$(echo "$tuserval" | cut -f2 -d:)
            local userexpireinseconds=$((userexp * 86400))
            local tglexp=$(date -d "@$userexpireinseconds" 2>/dev/null)
            local tgl=$(echo "$tglexp" | awk -F" " '{print $3}')

            while [ ${#tgl} -lt 2 ]; do
                tgl="0$tgl"
            done

            while [ ${#username} -lt 15 ]; do
                username="${username} "
            done

            local bulantahun=$(echo "$tglexp" | awk -F" " '{print $2, $6}')
            echo -e "Expired- User: $username Expire at: $tgl $bulantahun" >> /usr/local/bin/alluser
            local todaystime=$(date +%s)

            if [ "$userexpireinseconds" -ge "$todaystime" ]; then
                :
            else
                echo -e "Expired- Username: $username are expired at: $tgl $bulantahun and removed: $hariini" >> /usr/local/bin/deleteduser
                echo -e "Username $username that expired on $tgl $bulantahun removed from the VPS on $hariini"
                userdel "$username" &>/dev/null
                local TEXT="Expired user $username removed on $hariini."
                if [[ -n "$CHATID" && -n "$KEY" ]]; then
                    curl -s --max-time 10 -d "chat_id=$CHATID&text=$TEXT" "$URL" &>/dev/null
                fi
            fi
        done

        echo -e ""
        echo -e "Script has successfully run"
        echo -e "${ORANGE_SSH}--------------------------------------${NC}"
        echo -e ""
        read -n 1 -s -r -p "Press any key to back on menu"
        m_ssh
    }


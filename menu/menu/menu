install_python_env_and_deps() {
    local OS_ID=$(grep -oP '(?<=^ID=).+' /etc/os-release | tr -d '"')
    local OS_VERSION=$(grep -oP '(?<=^VERSION_ID=).+' /etc/os-release | tr -d '"')
    local OS_VERSION_CLEAN=${OS_VERSION//./}
    local OS_MAJOR="${OS_VERSION_CLEAN:0:2}"
    local PYTHON_EXEC_PATH="/usr/bin/python3"
    local VENV_PATH="/opt/python-env"

    if [[ ("$OS_ID" == "debian" && "$OS_MAJOR" -ge 12) || ("$OS_ID" == "ubuntu" && "$OS_MAJOR" -ge 24) ]]; then      
        echo -e "${yellow_text}OS Detected: $OS_ID $OS_VERSION, using Virtual Environment...${reset_text}"    
        apt update &>/dev/null && apt install -y python3-venv python3-pip python3-full pipx &>/dev/null
        python3 -m venv "$VENV_PATH" &>/dev/null   
        source "$VENV_PATH/bin/activate" &>/dev/null
        "$VENV_PATH/bin/pip" install --upgrade pip &>/dev/null
        echo "export PATH=\"$VENV_PATH/bin:\$PATH\"" >> ~/.bashrc
        source ~/.bashrc &>/dev/null
        PYTHON_EXEC_PATH="$VENV_PATH/bin/python3"
    else
        echo -e "${yellow_text}OS Detected: $OS_ID $OS_VERSION, using system Python...${reset_text}"   
        apt update &>/dev/null && apt install -y neofetch python3 python3-pip git unzip dos2unix &>/dev/null
    fi
    echo "$PYTHON_EXEC_PATH"
}

install_node_js() {
    local NODE_VERSION=$(node -v 2>/dev/null | grep -oP '(?<=v)\d+' || echo "0")
    if [ "$NODE_VERSION" -lt 20 ]; then
        echo -e "${yellow_text}Installing or upgrading Node.js to version 20...${reset_text}"
        curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - &>/dev/null || echo -e "${RED}Failed to download Node.js setup${NC}"
        apt-get install -y nodejs || echo -e "${RED}Failed to install Node.js${NC}"
        npm install -g npm@latest
    else
        echo -e "${green}Node.js is already installed and up-to-date (v$NODE_VERSION), skipping...${NC}"
    fi
    apt install -y build-essential libcairo2-dev libpango1.0-dev libjpeg-dev libgif-dev librsvg2-dev pkg-config libpixman-1-dev git curl cron 
    npm install -g npm@10
}


install_api_plugin() {
    local green="\e[38;5;82m"
    local red="\e[38;5;196m"
    local neutral="\e[0m"
    local orange="\e[38;5;130m"
    local blue="\e[38;5;39m"
    local yellow="\e[38;5;226m"
    local purple="\e[38;5;141m"
    local bold_white="\e[1;37m"
    local reset="\e[0m"
    local pink="\e[38;5;205m"

    print_rainbow() {
        local text="$1"
        local length=${#text}
        local start_color=(0 5 0)
        local mid_color=(0 200 0)
        local end_color=(0 5 0)

        for ((i = 0; i < length; i++)); do
            local progress=$(echo "scale=2; $i / ($length - 1)" | bc)

            if (($(echo "$progress < 0.5" | bc -l))); then
                local factor=$(echo "scale=2; $progress * 2" | bc)
                r=$(echo "scale=0; (${start_color[0]} * (1-$factor) + ${mid_color[0]} * $factor)/1" | bc)
                g=$(echo "scale=0; (${start_color[1]} * (1-$factor) + ${mid_color[1]} * $factor)/1" | bc)
                b=$(echo "scale=0; (${start_color[2]} * (1-$factor) + ${mid_color[2]} * $factor)/1" | bc)
            else
                local factor=$(echo "scale=2; ($progress - 0.5) * 2" | bc)
                r=$(echo "scale=0; (${mid_color[0]} * (1-$factor) + ${end_color[0]} * $factor)/1" | bc)
                g=$(echo "scale=0; (${mid_color[1]} * (1-$factor) + ${end_color[1]} * $factor)/1" | bc)
                b=$(echo "scale=0; (${mid_color[2]} * (1-$factor) + ${end_color[2]} * $factor)/1" | bc)
            fi
            printf "\e[38;2;%d;%d;%dm%s" "$r" "$g" "$b" "${text:$i:1}"
        done
        echo -e "$reset"
    }

    cek_status() {
        local status=$(systemctl is-active --quiet "$1" && echo "aktif" || echo "nonaktif")
        if [ "$status" = "aktif" ]; then
            echo -e "${green}GOOD${neutral}"
        else
            echo -e "${red}BAD${neutral}"
        fi
    }

    setup_plugin_files() {
